def draw_button(screen, font, rect, text, active=False):
    mouse_pos = pygame.mouse.get_pos()
    hover = rect.collidepoint(mouse_pos)

    base_color = (60, 60, 60)
    hover_color = (90, 90, 90)
    active_color = (70, 140, 255)

    # shadow
    shadow = rect.move(3, 3)
    pygame.draw.rect(screen, (20,20,20), shadow, border_radius=6)

    color = base_color
    if active:
        color = active_color
    elif hover:
        color = hover_color

    pygame.draw.rect(screen, color, rect, border_radius=6)

    # glow effect
    if active:
        glow_rect = rect.inflate(6, 6)
        pygame.draw.rect(screen, (100, 180, 255), glow_rect, 2, border_radius=8)

    text_surf = font.render(text, True, (255,255,255))
    screen.blit(
        text_surf,
        (
            rect.centerx - text_surf.get_width()//2,
            rect.centery - text_surf.get_height()//2
        )
    )

def write_data_yaml(dataset_dir: Path, class_map: dict):
    if not class_map:
        return

    names = [None] * len(class_map)
    for name, cid in class_map.items():
        names[cid] = name

    data = {
        "path": dataset_dir.as_posix(),
        "train": "images/train",
        "val": "images/val",
        "nc": len(names),
        "names": names,
    }

    yaml_path = dataset_dir / "data.yaml"
    yaml_path.write_text(
        yaml.dump(data, sort_keys=False, allow_unicode=True),
        encoding="utf-8"
    )

