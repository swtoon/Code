def point_in_polygon(px, py, polygon):
    """
    Ray casting algorithm
    """
    inside = False
    n = len(polygon)

    for i in range(n):
        x1, y1 = polygon[i]
        x2, y2 = polygon[(i + 1) % n]

        if ((y1 > py) != (y2 > py)) and \
           (px < (x2 - x1) * (py - y1) / (y2 - y1 + 1e-9) + x1):
            inside = not inside

    return inside

def detect_corner(mx, my, x, y, w, h):
    corners = {
        "tl": (x, y),
        "tr": (x + w, y),
        "bl": (x, y + h),
        "br": (x + w, y + h),
    }
    for name, (cx, cy) in corners.items():
        if abs(mx - cx) < HANDLE_SIZE and abs(my - cy) < HANDLE_SIZE:
            return name
    return None

